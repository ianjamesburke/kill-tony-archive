# ── Backend ──────────────────────────────────────────────────────────────────

# Path to SQLite DB (Railway: /data/kill_tony.db — set on the Volume mount)
DB_PATH=/data/kill_tony.db

# Comma-separated list of allowed frontend origins for CORS
ALLOWED_ORIGINS=https://your-frontend.railway.app

# Secret for the /admin/upload-db endpoint (use a strong random string)
ADMIN_SECRET=change-me

# Gemini API key (pipeline only — not needed on Railway)
GEMINI_API_KEY=

# ── Local pipeline → Railway sync ────────────────────────────────────────────

# Railway backend public URL (used by sync-db-to-railway.sh)
RAILWAY_BACKEND_URL=https://your-backend.railway.app

# Local DB path override for the sync script (defaults to data/kill_tony.db)
# DB_PATH_LOCAL=data/kill_tony.db


# ── Frontend ─────────────────────────────────────────────────────────────────

# Public URL of the deployed backend (Railway backend service URL)
VITE_API_BASE=https://your-backend.railway.app/api

# Public URL of this frontend service (required by SvelteKit for CSRF)
ORIGIN=https://your-frontend.railway.app
